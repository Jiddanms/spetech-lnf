
{
  "name": "spetech-lnf-web",
  "version": "1.0.0",
  "description": "Spetech Lost & Found Web",
  "main": "server.js",
  "engines": {
    "node": ">=14"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon --watch . --ext js,json --exec \"node server.js\"",
    "lint": "echo \"No linter configured\"",
    "init-db": "node -e \"require('./server.js')\"",
    "generate-qr-sample": "node -e \"(async()=>{const q=require('./utils/qrgenerator');await q.ensureDirs();console.log(await q.generateQrSvg('Gedung A'));})().catch(e=>{console.error(e);process.exit(1)})\""
  },
  "keywords": [
    "lost-and-found",
    "spetech",
    "qr",
    "express",
    "kti",
    "prototype"
  ],
  "author": "Spetech Team",
  "license": "MIT",
  "dependencies": {
    "bcrypt": "^5.1.0",
    "express": "^4.18.2",
    "fs-extra": "^11.1.1",
    "multer": "^1.4.5-lts.1",
    "qrcode": "^1.5.1",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "nodemon": "^2.0.22"
  }
}
